# ==============================================================================
# HiGI-Sentinel IDS — Final Production .gitignore
# ==============================================================================

# --- PYTHON ---
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# --- VIRTUAL ENVIRONMENTS ---
# Ignoramos el entorno virtual completo
ids_env/
venv/
.venv/
env/

# --- DATA SAFETY ---
# Ignoramos los PCAPs (son demasiado grandes para GitHub)
# Ignoramos todo el contenido de data/raw
data/raw/**
# Excepto los archivos .gitkeep para mantener la estructura
!**/data/raw/**/.gitkeep
data/raw/*.pcapng
data/raw/*.gz

# CONSERVAMOS los resultados procesados (CSV/JSON) para demostración
# (No hace falta añadir nada aquí, al no estar en la lista de arriba, se subirán)

# --- MODELS & BINARIES ---
# Ignoramos modelos entrenados (binarios .pkl) para mantener el repo ligero
# Se pueden regenerar con el script 'train'
models/*.pkl
models/*.joblib
models/scalers/*.pkl
# Pero conservamos las configuraciones JSON de los modelos si existen
!models/*.json

# --- LOGS ---
# Ignoramos los archivos de log locales
logs/*.log

# --- IDE & SYSTEM ---
.vscode/
.idea/
.DS_Store
Thumbs.db
.env

# --- MISC ---
build_codebase.sh
fullcodebase.md
